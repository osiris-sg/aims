# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key_here
CLERK_SECRET_KEY=your_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Backend API URL
# Local dev: http://localhost:4040
# Staging: your staging backend URL
# Production: your production backend URL
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:4040

# S3 Resource URL
NEXT_PUBLIC_RESOURCE_URL=https://aims-osiris.s3.ap-southeast-1.amazonaws.com/
