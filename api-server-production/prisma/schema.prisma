generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  skuKey            String
  categoryId        String             @db.Uuid
  description       String?
  image             String?
  organizationId    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?          @db.Timestamptz(6)
  category          Category           @relation(fields: [categoryId], references: [id])
  inventories       Inventory[]

  // 👇 New relation
  taggedTemplates   AssetTemplateTag[]

  @@unique([skuKey, deletedAt])
}


model Category {
  id             String  @id @default(uuid()) @db.Uuid
  name           String
  organizationId String?
  assets         Asset[]
}

model Inventory {
  id             String         @id @default(uuid()) @db.Uuid
  assetId        String         @db.Uuid
  location       String?
  status         String
  category       String
  quantity       Int?
  organizationId String
  sku            String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  asset          Asset          @relation(fields: [assetId], references: [id])
  timelineItems  TimelineItem[]
  documents      Document[]
  assignments    Assignment[]
}

model Customer {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  email             String             @unique
  phone             String
  address           String
  organizationId    String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  documents         Document[]
  projects          Project[]
}

model DocumentTemplate {
  id             String              @id @default(uuid()) @db.Uuid
  name           String?
  type           String
  organizationId String?
  config         Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // 👇 New relation
  taggedAssets   AssetTemplateTag[]
}

model AssetTemplateTag {
  id                 String           @id @default(uuid()) @db.Uuid
  assetId            String           @db.Uuid
  templateId         String           @db.Uuid
  createdAt          DateTime         @default(now())

  asset              Asset            @relation(fields: [assetId], references: [id])
  template           DocumentTemplate @relation(fields: [templateId], references: [id])

  @@unique([assetId, templateId]) // Prevent duplicates
}

model TimelineItem {
  id      String  @id @default(uuid()) @db.Uuid
  message String?
  pdfUrl  String?

  inventoryId String?    @db.Uuid
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])

  documentId String?   @db.Uuid
  document   Document? @relation(fields: [documentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id                 String    @id @default(uuid()) @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organizationId     String?
  documentTemplateId String
  type               String
  config             Json    // <- Stores all the RDO document field settings

  inventoryId        String?   @db.Uuid
  inventory          Inventory? @relation(fields: [inventoryId], references: [id])

  customerId         String?   @db.Uuid
  customer           Customer? @relation(fields: [customerId], references: [id])

  timelineItems      TimelineItem[]
  assignments        Assignment[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]
  userRoles   UserRole[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}
model Project {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  organizationId String?
  customerId     String         @db.Uuid
  customer       Customer       @relation(fields: [customerId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  startDate      DateTime?
  endDate        DateTime?
  status         ProjectStatus  @default(pending)

  assignments    Assignment[]
}

model Assignment {
  id          String     @id @default(uuid()) @db.Uuid
  projectId   String     @db.Uuid
  inventoryId String?    @db.Uuid
  documentId  String?    @db.Uuid
  startDate   DateTime?  @db.Timestamptz(6)
  endDate     DateTime?  @db.Timestamptz(6)
  createdAt   DateTime   @default(now())

  project     Project    @relation(fields: [projectId], references: [id])
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])
  document    Document?  @relation(fields: [documentId], references: [id])

  @@unique([projectId, inventoryId, documentId])
}

enum ProjectStatus {
  pending
  ongoing
  completed
}