generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    String                     @id @default(uuid())
  name                  String                     @unique
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  address               String?
  phoneNumber           String?
  registrationNumber    String?
  logo                  String?
  defaultStamp          String?
  customDocumentTypes   Json?
  taxRate               Float?                     @default(9)
  bankDetails           Json? // { accountName, accountNumber, bankName, swiftCode, branchCode, bankCode, currencyCode }
  stockDeductionTrigger String?                    @default("DO") // Legacy field - no longer used. Stock deduction logic: DO always deducts, Invoice deducts only if not extracted from DO
  assets                Asset[]
  categories            Category[]
  customers             Customer[]
  suppliers             Supplier[]
  documents             Document[]
  documentTemplates     DocumentTemplate[]
  inventories           Inventory[]
  projects              Project[]
  roles                 Role[]
  userOrganizations     UserOrganization[]
  userRoles             UserRole[]
  xeroConnection        XeroConnection?
  modules               OrganizationModule[]
  customFields          CustomField[]
  uiConfig              OrganizationUIConfig?
  priceHistories        PriceHistory[]
  payments              Payment[]
  transactions          Transaction[]
  customerBalances      CustomerBalance[]
  orders                Order[]
  quantityAdjustments   QuantityAdjustment[]
  importInvoices        ImportInvoice[]
  chartOfAccounts       ChartOfAccount[]
  accountingSetting     AccountingSetting?
  journalEntries        JournalEntry[]
  serviceReports        MaintenanceServiceReport[]
}

model Asset {
  id                  String                     @id @default(uuid()) @db.Uuid
  name                String
  skuKey              String
  categoryId          String                     @db.Uuid
  description         String?
  image               String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?                  @db.Timestamptz(6)
  organizationId      String?
  price               Float? // Legacy: treated as the selling price for backwards compatibility
  costPrice           Float? // What we pay to acquire/produce one unit (for margin tracking)
  customPrices        Json? // Optional [{ label: string, value: number }] — e.g. Listing Price, Dealer Price
  points              Float? // Asset-level discount (1 point = $1). Gated by enableAssetPoints flag.
  // Accessory asset IDs auto-added with this FCU on the FCU-CU (QF) quotation
  // (e.g. Sky Air: decoration panel + wired remote). Many-to-many — accessories
  // are shared across FCUs, so this is a tag list, not a parent/child relation.
  accessoryIds        String[]                   @default([])
  parentAssetId       String?                    @db.Uuid
  // Unit of Measure (e.g., PCS, EA, SET, BOX, KG, etc.)
  uom                 String                     @default("PCS")
  // Tracking mode: true = individual inventory items with SKUs, false = simple quantity
  isTracked           Boolean                    @default(true)
  // Quantity for untracked products (only used when isTracked = false)
  quantity            Int?
  // Minimum quantity threshold for low stock alerts
  minQuantity         Int?
  // Hardware UID of the NFC tag bound to this asset (chip serial number).
  // Set on first scan via the field PWA. Globally unique.
  nfcTagUid           String?                    @unique
  category            Category                   @relation(fields: [categoryId], references: [id])
  organization        Organization?              @relation(fields: [organizationId], references: [id])
  parentAsset         Asset?                     @relation("AssetHierarchy", fields: [parentAssetId], references: [id])
  subAssets           Asset[]                    @relation("AssetHierarchy")
  taggedTemplates     AssetTemplateTag[]
  inventories         Inventory[]
  priceHistories      PriceHistory[]
  quantityAdjustments QuantityAdjustment[]
  assignments         Assignment[]
  serviceReports      MaintenanceServiceReport[]

  @@unique([skuKey, organizationId, deletedAt])
}

model Category {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  organizationId String?
  assets         Asset[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Inventory {
  id             String                     @id @default(uuid()) @db.Uuid
  assetId        String                     @db.Uuid
  location       String?
  category       String
  quantity       Int?
  sku            String
  // Manufacturer's serial number from the equipment nameplate. Captured by
  // the field-scan AI extraction at bind time; used for audit / warranty
  // lookups. Distinct from `sku` (which is our own per-unit identifier).
  serialNumber   String?
  // Hardware UID of the NFC tag bound to this individual unit (chip serial).
  // Set via the field PWA's create-and-bind flow. Globally unique across orgs.
  // This is the primary NFC-binding column going forward; Asset.nfcTagUid is
  // legacy and only retained for backward compatibility.
  nfcTagUid      String?                    @unique
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  status         InventoryStatus
  organizationId String
  assignments    Assignment[]
  asset          Asset                      @relation(fields: [assetId], references: [id])
  organization   Organization               @relation(fields: [organizationId], references: [id])
  timelineItems  TimelineItem[]
  serviceReports MaintenanceServiceReport[]
}

model Customer {
  id              String            @id @default(uuid()) @db.Uuid
  customerCode    String? // Auto-generated code like CA001, CB002
  name            String
  email           String?
  phone           String?
  address         String?
  gstRegNo        String? // Customer's GST/Tax registration number
  salesmanId      String? // Reference to UserOrganization.id for the assigned salesman
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  salesman        UserOrganization? @relation(fields: [salesmanId], references: [id])
  siteOffices     SiteOffice[]
  priceHistories  PriceHistory[] // Track price history for this customer
  payments        Payment[]
  transactions    Transaction[]
  customerBalance CustomerBalance?  @relation("CustomerToBalance")
  projects        Project[]         @relation("CustomerProjects")
  orders          Order[]           @relation("CustomerOrders")

  @@unique([email, organizationId])
  @@unique([id, organizationId])
  @@unique([customerCode, organizationId])
  @@index([salesmanId])
}

model Supplier {
  id             String       @id @default(uuid()) @db.Uuid
  supplierCode   String?
  name           String
  email          String?
  phone          String?
  address        String?
  gstRegNo       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([email, organizationId])
  @@unique([id, organizationId])
  @@unique([supplierCode, organizationId])
}

model DocumentTemplate {
  id              String             @id @default(uuid()) @db.Uuid
  name            String?
  type            String // Document category: "INVOICE", "QUOTATION", "DELIVERY_ORDER", etc.
  templateVariant String             @default("Default") // Template design variant: "TI", "TI2", "QO1", "Default", etc.
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  config          Json?
  organizationId  String?
  // Template variant fields
  designName      String?            @default("Default")
  description     String?
  thumbnail       String? // URL to preview thumbnail
  isActive        Boolean            @default(false)
  isDefault       Boolean            @default(false) // System default template
  mockData        Json? // Mock data for preview
  layoutConfig    Json? // Layout-specific configuration
  styleConfig     Json? // Styling configuration
  taggedAssets    AssetTemplateTag[]
  organization    Organization?      @relation(fields: [organizationId], references: [id])

  @@index([organizationId, type, isActive])
  @@index([organizationId, type])
  @@index([organizationId, type, templateVariant])
}

model AssetTemplateTag {
  id         String           @id @default(uuid()) @db.Uuid
  assetId    String           @db.Uuid
  templateId String           @db.Uuid
  createdAt  DateTime         @default(now())
  asset      Asset            @relation(fields: [assetId], references: [id])
  template   DocumentTemplate @relation(fields: [templateId], references: [id])

  @@unique([assetId, templateId])
}

model TimelineItem {
  id          String     @id @default(uuid()) @db.Uuid
  message     String?
  pdfUrl      String?
  inventoryId String?    @db.Uuid
  documentId  String?    @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  document    Document?  @relation(fields: [documentId], references: [id])
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])
}

model Document {
  id                 String         @id @default(uuid()) @db.Uuid
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  config             Json // All form data stored here (customer, items, etc.)
  documentTemplateId String
  type               String // Document type: INVOICE, QUOTATION, etc.
  organizationId     String
  name               String? // Document number/identifier
  status             DocumentStatus @default(draft)

  // Revision fields for document versioning
  baseDocumentId String? @db.Uuid
  revisionNumber Int?    @default(0)

  // Project link
  projectId           String? @db.Uuid
  // Deployment link — for invoices/DOs that belong to a specific rental/sale event
  projectDeploymentId String? @db.Uuid

  organization       Organization               @relation(fields: [organizationId], references: [id])
  project            Project?                   @relation(fields: [projectId], references: [id])
  projectDeployment  ProjectDeployment?         @relation("DeploymentInvoices", fields: [projectDeploymentId], references: [id])
  sourcedDeployments ProjectDeployment[]        @relation("DeploymentSource")
  timelineItems      TimelineItem[]
  priceHistories     PriceHistory[] // Track price history entries from this document
  payments           Payment[] // Payments made against this document
  transactions       Transaction[] // Financial transactions from this document
  documentItems      DocumentItem[] // Junction table for efficient item queries
  assignments        Assignment[] // Source-of-truth link for assignments produced from this document
  maintenanceReports MaintenanceServiceReport[] // Field-side reports (DO_START / DO_ACK) linked to this document
  orderSources       Order[]                    @relation("OrderSourceQuotation") // Orders auto-created when this quotation was confirmed

  // Self-relation for revisions: base document -> many revisions
  baseDocument Document?  @relation("DocumentRevisions", fields: [baseDocumentId], references: [id])
  revisions    Document[] @relation("DocumentRevisions")

  @@unique([name, organizationId, documentTemplateId])
  @@index([baseDocumentId])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([projectId])
  @@index([projectDeploymentId])
}

// Junction table for document items - enables efficient queries for stock movements
model DocumentItem {
  id          String   @id @default(uuid()) @db.Uuid
  documentId  String   @db.Uuid
  itemId      String   @db.Uuid // Can be inventoryId or assetId
  itemType    ItemType // INVENTORY or ASSET
  sku         String? // SKU for reference
  description String? // Item description for reference
  quantity    Float    @default(0)
  unitPrice   Float?   @default(0)
  discount    Float?   @default(0)
  amount      Float?   @default(0)
  uom         String? // Unit of measure
  lineNumber  Int? // Position in document
  // True for service line items (labor, delivery fees, etc.).
  // Per Phase 5 Option 1, services from the import flow do NOT create DocumentItem
  // rows (they're skipped at the !inventoryItemId gate); this flag covers product
  // rows misclassified post-hoc as service, plus any future paths that DO create
  // service-row DocumentItems.
  isService   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, itemId, lineNumber])
  @@index([itemId])
  @@index([documentId])
  @@index([itemId, itemType])
}

enum ItemType {
  INVENTORY
  ASSET
}

model Role {
  id             String       @id @default(uuid())
  name           String
  description    String?
  allowedModules String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userRoles      UserRole[]
  permissions    Permission[] @relation("PermissionToRole")

  @@unique([name, organizationId])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")
}

model UserRole {
  id             String       @id @default(uuid())
  userId         String
  roleId         String
  createdAt      DateTime     @default(now())
  organizationId String
  assignedAt     DateTime     @default(now())
  assignedBy     String?
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId, organizationId])
}

model UserOrganization {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  salesmanCode   String? // Auto-generated code like S001, S002
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  joinedAt       DateTime     @default(now())
  lastActiveAt   DateTime?
  settings       Json?
  organization   Organization @relation(fields: [organizationId], references: [id])
  customers      Customer[] // Customers assigned to this salesman

  @@unique([userId, organizationId])
  @@unique([salesmanCode, organizationId])
}

model Project {
  id               String              @id @default(uuid()) @db.Uuid
  projectNumber    String? // e.g. PRJ-2026-001
  name             String
  description      String?
  organizationId   String?
  customerId       String?             @db.Uuid // direct FK; siteOffice still optional
  customerPoNumber String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  startDate        DateTime?
  endDate          DateTime?
  status           ProjectStatus       @default(pending)
  siteOfficeId     String?             @db.Uuid
  assignments      Assignment[]
  documents        Document[]
  deployments      ProjectDeployment[]
  organization     Organization?       @relation(fields: [organizationId], references: [id])
  siteOffice       SiteOffice?         @relation("SiteOfficeProjects", fields: [siteOfficeId], references: [id])
  customer         Customer?           @relation("CustomerProjects", fields: [customerId], references: [id])

  @@unique([projectNumber, organizationId])
  @@index([organizationId, status])
  @@index([customerId])
}

// A deployment groups one rental/sale event under a project.
// e.g. "DO202310-010 — 1× AF-90 monthly rental, deployed 2023-10-18"
// Recurring monthly invoices for that rental all link to the same deployment.
model ProjectDeployment {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String
  projectId      String @db.Uuid

  // Auto-assigned per project (1, 2, 3, ...). Displayed name is "Deployment N".
  // Nullable so existing rows aren't violated until the numbering pass runs.
  deploymentNumber Int?

  sourceDocumentId String?          @db.Uuid // The DO/invoice that started it (audit). Additional DOs attach via Document.projectDeploymentId.
  type             DeploymentType   @default(RENTAL)
  description      String? // Free-form user notes — no longer the displayed name.
  monthlyRate      Float? // for rentals; one-off price for sales
  currency         String?          @default("SGD")
  deployedDate     DateTime?
  offHiredDate     DateTime?
  status           DeploymentStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project        Project      @relation(fields: [projectId], references: [id])
  sourceDocument Document?    @relation("DeploymentSource", fields: [sourceDocumentId], references: [id])
  assignments    Assignment[]
  invoices       Document[]   @relation("DeploymentInvoices") // back-relation; now contains DOs AND invoices, partitioned by service-layer.

  @@unique([projectId, deploymentNumber])
  @@index([projectId, status])
  @@index([organizationId])
}

enum DeploymentType {
  RENTAL
  SALE
  SERVICE
}

enum DeploymentStatus {
  ACTIVE
  OFF_HIRED
  COMPLETED
  CANCELLED
}

model Assignment {
  id                  String  @id @default(uuid()) @db.Uuid
  projectId           String  @db.Uuid
  // Optional deployment grouping — assignments under a single rental/sale event
  projectDeploymentId String? @db.Uuid

  // Mode A: tracked inventory unit (existing)
  inventoryId String? @db.Uuid

  // Mode B: asset + quantity (new, for rentals without serials)
  assetId  String? @db.Uuid
  quantity Int?

  // Source invoice (idempotency on asset-mode + audit trail)
  documentId String? @db.Uuid

  startDate DateTime? @db.Timestamptz(6)
  endDate   DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now())

  inventory         Inventory?         @relation(fields: [inventoryId], references: [id])
  asset             Asset?             @relation(fields: [assetId], references: [id])
  document          Document?          @relation(fields: [documentId], references: [id])
  project           Project            @relation(fields: [projectId], references: [id])
  projectDeployment ProjectDeployment? @relation(fields: [projectDeploymentId], references: [id])

  @@unique([projectId, inventoryId])
  @@unique([projectId, assetId, documentId])
  @@index([assetId])
  @@index([documentId])
  @@index([projectDeploymentId])
}

model SiteOffice {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  address        String?
  customerId     String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  contactDetails ContactDetail[]
  projects       Project[]       @relation("SiteOfficeProjects")
  customer       Customer        @relation(fields: [customerId], references: [id])
}

model ContactDetail {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  email        String
  phone        String
  siteOfficeId String     @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  siteOffice   SiteOffice @relation(fields: [siteOfficeId], references: [id])
}

model AuditLog {
  id             String      @id @default(uuid())
  userId         String
  userName       String?
  userEmail      String?
  action         String
  resource       String
  resourceId     String?
  resourceName   String?
  organizationId String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  status         AuditStatus @default(SUCCESS)
  errorMessage   String?
  createdAt      DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([organizationId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resource, createdAt])
  @@index([organizationId, action, createdAt])
  @@index([userId, action, createdAt])
}

enum ProjectStatus {
  pending
  ongoing
  completed
}

enum InventoryStatus {
  instock
  rental
  reserved
  maintenance
  sold
}

enum DocumentStatus {
  draft
  confirmed
  pending_delivery
  delivered_not_installed
  delivered_installed
  pending_payment
  paid
  pending_return
  returned
}

enum AuditStatus {
  SUCCESS
  FAILURE
  PENDING
}

model XeroConnection {
  id                    String       @id @default(uuid()) @db.Uuid
  organizationId        String       @unique
  tenantId              String       @unique
  accessToken           String
  refreshToken          String
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Module configuration per organization
// Orders — auto-created when a quotation is confirmed. Acts as the parent
// container from which POs / DOs / Invoices can be spun off for the items.
// Status is intentionally a free-form string for v1 (no auto-advance).
model Order {
  id                String   @id @default(uuid()) @db.Uuid
  orderNumber       String // e.g. ORD202605-001
  organizationId    String
  customerId        String?  @db.Uuid
  sourceQuotationId String?  @db.Uuid // Document.id of the originating quotation
  status            String   @default("DRAFT") // DRAFT / IN_PROGRESS / COMPLETED / CANCELLED (free-form)
  items             Json // Snapshot at order-creation time: [{ itemCode, description, quantity, unitPrice, costPrice?, taggedAssetCode?, ... }]
  linkedDocuments   Json? // { po: [{id,name}], do: [{id,name}], invoice: [{id,name}] }
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  customer        Customer?    @relation("CustomerOrders", fields: [customerId], references: [id])
  sourceQuotation Document?    @relation("OrderSourceQuotation", fields: [sourceQuotationId], references: [id])

  @@unique([orderNumber, organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([sourceQuotationId])
}

model OrganizationModule {
  id             String       @id @default(uuid())
  organizationId String
  moduleCode     String // 'ASSETS', 'INVENTORY', 'DOCUMENTS', 'PROJECTS', 'CUSTOMERS', 'INVOICES'
  enabled        Boolean      @default(true)
  displayName    String? // Custom label for this module
  icon           String? // Custom icon (Material UI icon name)
  sortOrder      Int? // Navigation order
  config         Json? // Module-specific configuration (routes, permissions, etc.)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, moduleCode])
  @@index([organizationId])
}

// Custom fields per organization per entity
model CustomField {
  id             String             @id @default(uuid())
  organizationId String
  entityType     String // 'Asset', 'Customer', 'Document', 'Inventory', 'Project'
  fieldName      String // Technical name (e.g., 'warranty_date')
  displayLabel   String // User-facing label (e.g., 'Warranty Expiry Date')
  fieldType      String // 'text', 'number', 'date', 'select', 'multiselect', 'boolean', 'file', 'richtext'
  required       Boolean            @default(false)
  options        Json? // For select/multiselect fields: [{value: 'val1', label: 'Label 1'}]
  defaultValue   String?
  validation     Json? // Validation rules: {min: 0, max: 100, pattern: '^[A-Z]'}
  sortOrder      Int?               @default(0)
  isActive       Boolean            @default(true)
  showInList     Boolean            @default(false) // Show in list/table views
  showInForm     Boolean            @default(true) // Show in forms
  groupName      String? // Group fields together in forms
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])
  fieldValues    CustomFieldValue[]

  @@unique([organizationId, entityType, fieldName])
  @@index([organizationId, entityType])
}

// Store custom field values
model CustomFieldValue {
  id            String      @id @default(uuid())
  customFieldId String
  entityId      String // ID of the Asset/Customer/etc.
  entityType    String // 'Asset', 'Customer', etc.
  value         Json // Flexible storage for any type of value
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityId])
  @@index([entityId, entityType])
}

// UI Configuration per organization
model OrganizationUIConfig {
  id               String       @id @default(uuid())
  organizationId   String       @unique
  theme            Json? // Colors, fonts, spacing: {primaryColor: '#..', secondaryColor: '#..'}
  navigationConfig Json? // Custom navigation structure
  dashboardLayout  Json? // Dashboard widget configuration
  terminology      Json? // Custom labels: {asset: 'Equipment', customer: 'Client'}
  dateFormat       String?      @default("MM/dd/yyyy")
  timeFormat       String?      @default("12h")
  currency         String?      @default("USD")
  language         String?      @default("en")
  features         Json? // Feature flags: {enableProjects: true, enableDocumentAI: false}
  branding         Json? // Additional branding config
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id])
}

// Price History for tracking item prices from confirmed invoices
model PriceHistory {
  id             String   @id @default(uuid())
  assetId        String   @db.Uuid // Reference to the asset/item sold (REQUIRED)
  unitPrice      Float // Unit price at time of sale
  quantity       Float // Quantity sold
  uom            String? // Unit of measure
  totalAmount    Float // Total amount for this line item
  documentId     String   @db.Uuid // Reference to the document (invoice)
  documentNumber String // Invoice number for reference
  documentDate   DateTime // Date of the invoice
  customerId     String?  @db.Uuid // Customer who bought it
  customerName   String? // Customer name for reference
  organizationId String // Organization ID
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  document     Document     @relation(fields: [documentId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  asset        Asset        @relation(fields: [assetId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  // Indexes for fast queries
  @@index([assetId, organizationId])
  @@index([customerId, organizationId])
  @@index([documentDate])
  @@index([createdAt])
}

// Payment tracking for invoices
model Payment {
  id             String   @id @default(uuid())
  organizationId String
  customerId     String   @db.Uuid
  documentId     String   @db.Uuid
  amount         Float
  paymentDate    DateTime
  paymentMethod  String // cash, check, transfer, etc
  reference      String? // check number, transfer reference
  notes          String?
  createdBy      String // user ID who recorded payment
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  document     Document     @relation(fields: [documentId], references: [id])

  // Create related transaction when payment is recorded
  transactions Transaction[]

  @@index([customerId, organizationId])
  @@index([documentId])
  @@index([paymentDate])
  @@index([organizationId, paymentDate])
}

// Unified transaction ledger for all financial activities
model Transaction {
  id              String          @id @default(uuid())
  organizationId  String
  customerId      String          @db.Uuid
  transactionType TransactionType // invoice, payment, credit_note, debit_note, adjustment, opening_balance
  documentId      String?         @db.Uuid // nullable for adjustments/opening balance
  paymentId       String? // for payment transactions
  transactionDate DateTime
  reference       String? // document number or payment reference
  description     String
  debit           Float           @default(0)
  credit          Float           @default(0)
  balance         Float           @default(0) // running balance at time of transaction
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  document     Document?    @relation(fields: [documentId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  // Indexes for fast SOA queries
  @@index([customerId, transactionDate])
  @@index([organizationId, transactionDate])
  @@index([documentId])
  @@index([paymentId])
}

// Customer balance tracking
model CustomerBalance {
  id                  String    @id @default(uuid())
  organizationId      String
  customerId          String    @db.Uuid
  openingBalance      Float     @default(0)
  currentBalance      Float     @default(0)
  lastTransactionDate DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation("CustomerToBalance", fields: [customerId, organizationId], references: [id, organizationId])

  @@unique([customerId, organizationId])
  @@index([organizationId])
}

enum TransactionType {
  INVOICE
  PAYMENT
  CREDIT_NOTE
  DEBIT_NOTE
  ADJUSTMENT
  OPENING_BALANCE
}

// Quantity adjustment history for untracked products
model QuantityAdjustment {
  id             String         @id @default(uuid()) @db.Uuid
  assetId        String         @db.Uuid
  previousQty    Int // Quantity before adjustment
  newQty         Int // Quantity after adjustment
  adjustmentType AdjustmentType // add, subtract, set
  amount         Int // Amount adjusted
  reason         String? // Optional reason for adjustment
  adjustedBy     String // User name/email who made the adjustment
  adjustedAt     DateTime       @default(now())
  organizationId String
  createdAt      DateTime       @default(now())

  // Relations
  asset        Asset        @relation(fields: [assetId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  // Indexes for fast queries
  @@index([assetId, adjustedAt])
  @@index([organizationId, adjustedAt])
}

enum AdjustmentType {
  ADD
  SUBTRACT
  SET
}

// Import staging table for Xero invoice backfill
model ImportInvoice {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String
  invoiceNumber     String
  date              String?
  customer          String?
  customerMatched   Boolean   @default(false)
  status            String? // Xero status: Paid, Approved, Draft
  source            String? // Receivable Invoice or Credit Note
  gross             Float?
  balance           Float?
  // AI-extracted metadata
  projectName       String?
  projectLocation   String?
  siteOfficeName    String?
  siteOfficeAddress String?
  doDate            String?
  doNumber          String?
  contactName       String?
  contactPhone      String?
  // Line items stored as JSON array
  lineItems         Json // Array of line item objects with asset_match, serial_numbers, etc.
  // Review status
  reviewStatus      String    @default("pending") // pending, confirmed, skipped
  skipReason        String?
  confirmedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([invoiceNumber, organizationId])
  @@index([organizationId, reviewStatus])
  @@index([organizationId])
}

// ============================================================
// ACCOUNTING
// ============================================================

// Chart of Accounts — one row per GL account per organization.
// Code prefixes follow the A's / Singapore SME convention:
//   Sxxxx = Sales, Cxxxx = Purchase / Cost of Sales, Ixxxx = Income,
//   Exxxx = Expenses, TXxxx = Tax, XIxxx = Extraordinary,
//   FAxxx = Fixed Assets, IAxxx = Intangible, CAxxx = Current Assets,
//   CLxxx = Current Liabilities, MTxxx/LTxxx = Medium/Long Term Liabilities,
//   DVxxx = Dividends, PCxxx = Share Capital, PDxxx = Depreciation Provision,
//   RPxxx = Retained Profit, CRxxx = Capital Reserve.
model ChartOfAccount {
  id               String   @id @default(uuid())
  organizationId   String
  code             String // e.g., "S0001", "CA001", "CL300"
  name             String // e.g., "Credit Sales", "Trade Receivables"
  description      String?
  accountType      String // High-level type — see AccountType enum-ish values in service
  category         String // 'PNL' | 'BALANCE_SHEET'
  normalBalance    String // 'DEBIT' | 'CREDIT'
  isControlAccount Boolean  @default(false) // Debtor / Creditor / GST control accounts
  isSystem         Boolean  @default(false) // Seeded by default; cannot be deleted
  isActive         Boolean  @default(true)
  parentAccountId  String? // Optional sub-account hierarchy
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ChartOfAccount?    @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  children     ChartOfAccount[]   @relation("AccountHierarchy")
  journalLines JournalEntryLine[]

  @@unique([organizationId, code])
  @@index([organizationId, accountType])
  @@index([organizationId, category])
}

// One-per-organization accounting configuration (A's "Installation" screen).
model AccountingSetting {
  id             String @id @default(uuid())
  organizationId String @unique

  // ---------- Operation Settings ----------
  baseCurrency          String  @default("SGD")
  // Next-number counters per document type (e.g. { "invoice": 119, "quotation": 22, ... })
  nextNumbers           Json?
  // Per-doc-type prefix overrides (e.g. { "invoice": "INV", "quotation": "QO" })
  numberPrefixes        Json?
  activateLastSoldPrice Boolean @default(true)
  activateLastBuyPrice  Boolean @default(true)

  // ---------- Accounts Settings ----------
  yearOpeningDate   DateTime?
  yearOpeningStock  Float?    @default(0)
  monthOpeningDate  DateTime?
  monthOpeningStock Float?    @default(0)
  monthClosingStock Float?    @default(0)

  // ---------- Tax Settings ----------
  taxRegistrationNumber String?
  taxDefaultPercentage  Float?  @default(9)
  taxReference          String? @default("GST") // GST / VAT / etc.

  // ---------- Accounts Definition ----------
  // Code-range windows (e.g. { sales: { from: "S0001", to: "S9999" }, ... })
  accountCodeRanges Json?
  // Control-account code references (e.g. { debtorControl: "CA001", creditorControl: "CL001", taxLiabilities: "CL300", ... })
  controlAccounts   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================================
// JOURNAL ENTRIES — General Ledger
// ============================================================
//
// JournalEntry is the GL header (one transaction = many balanced lines).
// Auto-created on invoice confirm + payment record, plus manual entries
// (Journal Voucher). Posting locks the entry; voiding creates a reversing entry.

model JournalEntry {
  id             String   @id @default(uuid())
  organizationId String
  journalNumber  String // e.g., "JV-000001"
  entryDate      DateTime
  type           String // MANUAL | INVOICE | PAYMENT | CREDIT_NOTE | DEBIT_NOTE | OPENING_BALANCE | ADJUSTMENT
  status         String   @default("DRAFT") // DRAFT | POSTED | VOID
  reference      String? // Source document number, payment reference, etc.
  description    String?
  totalDebit     Float    @default(0)
  totalCredit    Float    @default(0)
  currency       String   @default("SGD")

  // Source linkage (only one is set depending on type)
  sourceDocumentId String?
  sourcePaymentId  String?

  postedAt        DateTime?
  postedBy        String?
  voidedAt        DateTime?
  voidedBy        String?
  reversesEntryId String? // If this is a reversing entry, points to original

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines        JournalEntryLine[]

  @@unique([organizationId, journalNumber])
  @@index([organizationId, entryDate])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([sourceDocumentId])
  @@index([sourcePaymentId])
}

model JournalEntryLine {
  id             String  @id @default(uuid())
  journalEntryId String
  accountId      String // FK to ChartOfAccount.id
  lineNumber     Int
  description    String?
  debit          Float   @default(0)
  credit         Float   @default(0)

  // Multi-currency support — set when the org operates in multiple currencies
  foreignAmount Float?
  exchangeRate  Float?

  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// Field-service maintenance report captured via the NFC scan PWA.
// One per service visit; tied to an asset, signed by the customer/recipient on-site.
model MaintenanceServiceReport {
  id               String                         @id @default(uuid()) @db.Uuid
  organizationId   String
  assetId          String                         @db.Uuid
  // Optional link to a specific inventory unit (when isTracked assets have serials)
  inventoryId      String?                        @db.Uuid
  // Clerk user id of the technician who performed the work
  technicianUserId String
  technicianName   String?
  description      String // What was serviced / issue / resolution
  // S3 keys for proof-of-service photos
  photos           String[]                       @default([])
  // S3 key OR base64 PNG (matches Document signature handling)
  signature        String?
  signedByName     String? // Customer / recipient name
  signedAt         DateTime?
  status           MaintenanceServiceReportStatus @default(draft)
  // Discriminator for what kind of field activity this row represents.
  // SERVICE   — traditional maintenance/repair visit (default).
  // DO_START  — technician started delivery of an existing DO (label: "Delivery Started").
  // DO_ACK    — technician confirmed final handover/installation of a DO (label: "Delivery Acknowledged").
  kind             MaintenanceReportKind          @default(SERVICE)
  // FK to the Document this report relates to.
  //   DO_START / DO_ACK → the DO being delivered.
  //   SERVICE           → null.
  // Historic DO_ACK rows backfilled from the description-prefix scheme may
  // have null documentId; gating logic only considers MSRs with non-null FK.
  documentId       String?                        @db.Uuid
  document         Document?                      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  // GPS captured at submission time. Optional — submission proceeds without
  // GPS if browser geolocation is denied or unavailable.
  latitude         Float?
  longitude        Float?
  // Reverse-geocoded human-readable label (e.g. "12 Tuas South Ave 3").
  // Schema-ready for future enablement; v1 of the field flow leaves it null.
  locationLabel    String?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  organization  Organization           @relation(fields: [organizationId], references: [id])
  asset         Asset                  @relation(fields: [assetId], references: [id])
  inventory     Inventory?             @relation(fields: [inventoryId], references: [id])
  // Background-tracked GPS pings collected during this delivery. Populated
  // only for kind=DO_START rows — DO_ACK and SERVICE rows have none.
  locationPings DeliveryLocationPing[]

  @@index([organizationId, assetId, createdAt])
  @@index([assetId, status])
  @@index([organizationId, kind, createdAt])
  @@index([documentId, kind])
}

// Live-tracked GPS pings emitted by the field-tech app between Start Delivery
// and Acknowledge Delivery. Linked to the DO_START MaintenanceServiceReport;
// the office portal renders these as a polyline on a Leaflet map.
//
// Cardinality: 1 DO_START → N pings (typically 1 every 10s while delivery
// active). Cascade-deleted with the parent report.
model DeliveryLocationPing {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @db.Uuid
  latitude  Float
  longitude Float
  accuracy  Float? // metres of horizontal uncertainty (68% confidence)
  speed     Float? // metres per second
  heading   Float? // degrees from true north (0..360)
  timestamp DateTime // capture time from the phone
  createdAt DateTime @default(now()) // server-side receive time

  report MaintenanceServiceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Idempotency anchor — duplicate batch retries don't double-insert.
  @@unique([reportId, timestamp])
  // Lookups are always "all pings for report X, ordered by time" → composite
  // index covers both filter and order.
  @@index([reportId, timestamp])
}

enum MaintenanceServiceReportStatus {
  draft
  completed
}

enum MaintenanceReportKind {
  SERVICE
  DO_START
  DO_ACK
}
