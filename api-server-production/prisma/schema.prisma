generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // pg_trgm backs the GIN trigram indexes on *.name (fast ILIKE-contains search).
  // Only pg_trgm is declared — the DB has no other user extensions (just the
  // built-in plpgsql, which Prisma never manages), so db:push drops nothing.
  extensions = [pg_trgm]
}

model Organization {
  id                    String                     @id @default(uuid())
  name                  String                     @unique
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  address               String?
  phoneNumber           String?
  registrationNumber    String?
  logo                  String?
  defaultStamp          String?
  customDocumentTypes   Json?
  taxRate               Float?                     @default(9)
  // Org-wide defaults for the per-document tax toggles. The document editor
  // seeds new docs from these (documentInfo.taxApplicable / .absorbTax) so a
  // user who normally invoices with GST on top doesn't have to flip the
  // switch on every new draft. Per-doc overrides still win when set.
  taxApplicable         Boolean                    @default(true)
  absorbTax             Boolean                    @default(false)
  // ISO currency code (e.g. SGD, USD, MYR) used as the default for new
  // documents (documentInfo.currency). Per-doc overrides still win.
  defaultCurrency       String                     @default("SGD")
  // Round-down step for QF quote totals. Project quotes round the
  // Discounted Price (pre-GST) down to this step and roll the absorbed
  // amount into the Discount line. Route Order quotes round the Nett
  // Total (post-GST) down to this step and surface the crumb as a final
  // "Round-down" line. 0 = no rounding.
  quoteRoundingStep     Int                        @default(10)
  // Per-doc-type defaults for T&Cs / Notes / Footer message. Keyed by the
  // doc's `type` value (e.g. "QO1", "PO", "INVOICE"). Each entry is:
  // { tnc?: string, notes?: string, footerMessage?: string }. Seeded onto
  // documentInfo on new docs (per-doc overrides still win). Edited from
  // Company Profile → Doc Defaults tab.
  docTypeDefaults       Json?
  bankDetails           Json? // { accountName, accountNumber, bankName, swiftCode, branchCode, bankCode, currencyCode }
  stockDeductionTrigger String?                    @default("DO") // Legacy field - no longer used. Stock deduction logic: DO always deducts, Invoice deducts only if not extracted from DO
  // Org-wide reward Points ledger. Float so partial-point adjustments stay
  // representable; decremented when a Route Order PO is confirmed by the
  // user's chosen "Less Points" amount on that PO. Inline-editable so the
  // user can seed it once Daikin tells them their starting balance.
  pointsBalance         Float?                     @default(0)
  assets                Asset[]
  categories            Category[]
  customers             Customer[]
  suppliers             Supplier[]
  documents             Document[]
  documentTemplates     DocumentTemplate[]
  inventories           Inventory[]
  projects              Project[]
  roles                 Role[]
  userOrganizations     UserOrganization[]
  userRoles             UserRole[]
  xeroConnection        XeroConnection?
  modules               OrganizationModule[]
  customFields          CustomField[]
  uiConfig              OrganizationUIConfig?
  priceHistories        PriceHistory[]
  payments              Payment[]
  transactions          Transaction[]
  customerBalances      CustomerBalance[]
  orders                Order[]
  quantityAdjustments   QuantityAdjustment[]
  importInvoices        ImportInvoice[]
  chartOfAccounts       ChartOfAccount[]
  accountingSetting     AccountingSetting?
  journalEntries        JournalEntry[]
  recurringJournals     RecurringJournalTemplate[]
  costCenters           CostCenter[]
  fixedAssets           FixedAsset[]
  budgets               Budget[]
  bills                 Bill[]
  billPayments          BillPayment[]
  bankImports           BankStatementImport[]
  xeroAccountMappings   XeroAccountMapping[]
  xeroSyncRuns          XeroSyncRun[]
  serviceReports        MaintenanceServiceReport[]
}

model Asset {
  id                  String                     @id @default(uuid()) @db.Uuid
  name                String
  skuKey              String
  categoryId          String                     @db.Uuid
  description         String?
  image               String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?                  @db.Timestamptz(6)
  organizationId      String?
  price               Float? // Legacy: treated as the selling price for backwards compatibility
  costPrice           Float? // What we pay to acquire/produce one unit (for margin tracking)
  customPrices        Json? // Optional [{ label: string, value: number }] — e.g. Listing Price, Dealer Price
  points              Float? // Asset-level discount (1 point = $1). Gated by enableAssetPoints flag.
  capacityKw          Float? // Nominal cooling capacity in kW (e.g. VRV outdoor/indoor units). Null for items without a capacity rating (accessories, kits).
  // Accessory asset IDs auto-added with this FCU on the FCU-CU (QF) quotation
  // (e.g. Sky Air: decoration panel + wired remote). Many-to-many — accessories
  // are shared across FCUs, so this is a tag list, not a parent/child relation.
  accessoryIds        String[]                   @default([])
  // Additional accessory OPTIONS (e.g. black panel, wireless remote): not auto-added,
  // but shown in this FCU's scoped accessory picker so they're swappable.
  accessoryOptionIds  String[]                   @default([])
  parentAssetId       String?                    @db.Uuid
  // Unit of Measure (e.g., PCS, EA, SET, BOX, KG, etc.)
  uom                 String                     @default("PCS")
  // Tracking mode: true = individual inventory items with SKUs, false = simple quantity
  isTracked           Boolean                    @default(true)
  isExternal          Boolean                    @default(true)
  // Quantity for untracked products (only used when isTracked = false)
  quantity            Int?
  // Minimum quantity threshold for low stock alerts
  minQuantity         Int?
  // Hardware UID of the NFC tag bound to this asset (chip serial number).
  // Set on first scan via the field PWA. Globally unique.
  nfcTagUid           String?                    @unique
  waterSgProductLine  String?
  category            Category                   @relation(fields: [categoryId], references: [id])
  organization        Organization?              @relation(fields: [organizationId], references: [id])
  parentAsset         Asset?                     @relation("AssetHierarchy", fields: [parentAssetId], references: [id])
  subAssets           Asset[]                    @relation("AssetHierarchy")
  taggedTemplates     AssetTemplateTag[]
  inventories         Inventory[]
  priceHistories      PriceHistory[]
  quantityAdjustments QuantityAdjustment[]
  assignments         Assignment[]
  serviceReports      MaintenanceServiceReport[]

  @@unique([skuKey, organizationId, deletedAt])
}

model Category {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  organizationId String?
  assets         Asset[]
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Inventory {
  id             String                     @id @default(uuid()) @db.Uuid
  assetId        String                     @db.Uuid
  location       String?
  category       String
  quantity       Int?
  sku            String
  // Manufacturer's serial number from the equipment nameplate. Captured by
  // the field-scan AI extraction at bind time; used for audit / warranty
  // lookups. Distinct from `sku` (which is our own per-unit identifier).
  serialNumber   String?
  cameraP2P      String?
  // Hardware UID of the NFC tag bound to this individual unit (chip serial).
  // Set via the field PWA's create-and-bind flow. Globally unique across orgs.
  // This is the primary NFC-binding column going forward; Asset.nfcTagUid is
  // legacy and only retained for backward compatibility.
  nfcTagUid      String?                    @unique
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  status         InventoryStatus
  organizationId String
  assignments    Assignment[]
  asset          Asset                      @relation(fields: [assetId], references: [id])
  organization   Organization               @relation(fields: [organizationId], references: [id])
  timelineItems  TimelineItem[]
  serviceReports MaintenanceServiceReport[]

  // Backs the SKU-match bind: a SKU identifies one unit within an org, so
  // create-and-bind can resolve an existing unit by (sku, organizationId).
  // Enforces what generateSkuRange only assumed — a concurrent SKU collision
  // now surfaces as a clean P2002 instead of a silent duplicate.
  @@unique([sku, organizationId])
}

model Customer {
  id              String            @id @default(uuid()) @db.Uuid
  customerCode    String? // Auto-generated code like CA001, CB002
  name            String
  email           String?
  phone           String?
  address         String?
  gstRegNo        String? // Customer's GST/Tax registration number
  salesmanId      String? // Reference to UserOrganization.id for the assigned salesman
  // Xero pull-sync: ContactID from Xero (null = not yet synced).
  xeroId          String?           @unique
  xeroLastSyncAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  salesman        UserOrganization? @relation(fields: [salesmanId], references: [id])
  siteOffices     SiteOffice[]
  priceHistories  PriceHistory[] // Track price history for this customer
  payments        Payment[]
  transactions    Transaction[]
  customerBalance CustomerBalance?  @relation("CustomerToBalance")
  projects        Project[]         @relation("CustomerProjects")
  orders          Order[]           @relation("CustomerOrders")
  contacts        CustomerContact[]

  @@unique([email, organizationId])
  @@unique([id, organizationId])
  @@unique([customerCode, organizationId])
  @@index([salesmanId])
  // Fast case-insensitive substring search (ILIKE %term%) on customer name.
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

model Supplier {
  id             String       @id @default(uuid()) @db.Uuid
  supplierCode   String?
  name           String
  email          String?
  phone          String?
  address        String?
  gstRegNo       String?
  // Xero pull-sync: ContactID from Xero (suppliers are also Contacts in Xero).
  xeroId         String?      @unique
  xeroLastSyncAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  bills          Bill[]
  billPayments   BillPayment[]

  @@unique([email, organizationId])
  @@unique([id, organizationId])
  @@unique([supplierCode, organizationId])
}

model DocumentTemplate {
  id              String             @id @default(uuid()) @db.Uuid
  name            String?
  type            String // Document category: "INVOICE", "QUOTATION", "DELIVERY_ORDER", etc.
  templateVariant String             @default("Default") // Template design variant: "TI", "TI2", "QO1", "Default", etc.
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  config          Json?
  organizationId  String?
  // Template variant fields
  designName      String?            @default("Default")
  description     String?
  thumbnail       String? // URL to preview thumbnail
  isActive        Boolean            @default(false)
  isDefault       Boolean            @default(false) // System default template
  mockData        Json? // Mock data for preview
  layoutConfig    Json? // Layout-specific configuration
  styleConfig     Json? // Styling configuration
  taggedAssets    AssetTemplateTag[]
  organization    Organization?      @relation(fields: [organizationId], references: [id])
  // Per-org activation selections (cascade-cleaned on template delete).
  activeSelections OrganizationActiveTemplate[]

  @@index([organizationId, type, isActive])
  @@index([organizationId, type])
  @@index([organizationId, type, templateVariant])
}

// Which shared DocumentTemplate an organization has activated for a given
// document type. Templates form a cross-org shared pool; this table records
// per-org selection so one template can be active for some orgs and not others.
// Standalone (no relations) to avoid back-relation churn on Organization.
model OrganizationActiveTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String
  type           String // Document type, e.g. "QUOTATION"
  templateId     String   @db.Uuid
  // Multiple templates can be active per org+type. isPrimary marks the ONE used
  // as the default for headless creation (AI upload / quick-create) and the
  // pre-selected option in the creation picker. At most one primary per org+type
  // (enforced in the service, not the DB).
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // FK to the activated template so deleting a template cascades its selection
  // rows (fixes dangling OAT rows on template delete).
  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type, templateId])
  @@index([templateId])
}

model AssetTemplateTag {
  id         String           @id @default(uuid()) @db.Uuid
  assetId    String           @db.Uuid
  templateId String           @db.Uuid
  createdAt  DateTime         @default(now())
  asset      Asset            @relation(fields: [assetId], references: [id])
  template   DocumentTemplate @relation(fields: [templateId], references: [id])

  @@unique([assetId, templateId])
}

model TimelineItem {
  id          String     @id @default(uuid()) @db.Uuid
  message     String?
  pdfUrl      String?
  inventoryId String?    @db.Uuid
  documentId  String?    @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  document    Document?  @relation(fields: [documentId], references: [id])
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])
}

model Document {
  id                 String         @id @default(uuid()) @db.Uuid
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  config             Json // All form data stored here (customer, items, etc.)
  documentTemplateId String
  type               String // Document type: INVOICE, QUOTATION, etc.
  organizationId     String
  name               String? // Document number/identifier
  status             DocumentStatus @default(draft)

  // Revision fields for document versioning
  baseDocumentId String? @db.Uuid
  revisionNumber Int?    @default(0)

  // Concurrent-edit guard (presence lock + optimistic concurrency).
  // editingAt = heartbeat (editor open); lastActivityAt = last real content
  // edit. Take-over is allowed only when lastActivityAt is >5 min stale.
  // version increments on every successful save; a save carrying an older
  // version is rejected (409) so a stale copy can't clobber newer work.
  editingByUserId String?
  editingByName   String?
  editingAt       DateTime?
  lastActivityAt  DateTime?
  version         Int       @default(0)

  // Project link
  projectId           String? @db.Uuid
  // Deployment link — for invoices/DOs that belong to a specific rental/sale event
  projectDeploymentId String? @db.Uuid

  // Generic file attachments (supplier PDFs, payment receipts, supporting
  // docs). Same shape as Bill.attachments:
  //   [{ fileKey, fileName, mimeType, label?, uploadedAt, uploadedBy }]
  attachments         Json?

  organization       Organization               @relation(fields: [organizationId], references: [id])
  project            Project?                   @relation(fields: [projectId], references: [id])
  projectDeployment  ProjectDeployment?         @relation("DeploymentInvoices", fields: [projectDeploymentId], references: [id])
  sourcedDeployments ProjectDeployment[]        @relation("DeploymentSource")
  timelineItems      TimelineItem[]
  priceHistories     PriceHistory[] // Track price history entries from this document
  payments           Payment[] // Payments made against this document
  transactions       Transaction[] // Financial transactions from this document
  documentItems      DocumentItem[] // Junction table for efficient item queries
  assignments        Assignment[] // Source-of-truth link for assignments produced from this document
  maintenanceReports MaintenanceServiceReport[] // Field-side reports (DO_START / DO_ACK) linked to this document
  msrInvoices        MaintenanceServiceReport[] @relation("MsrInvoice") // Service reports that produced THIS invoice
  orderSources       Order[]                    @relation("OrderSourceQuotation") // Orders auto-created when this quotation was confirmed

  // Self-relation for revisions: base document -> many revisions
  baseDocument Document?  @relation("DocumentRevisions", fields: [baseDocumentId], references: [id])
  revisions    Document[] @relation("DocumentRevisions")

  @@unique([name, organizationId, documentTemplateId])
  @@index([baseDocumentId])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([projectId])
  @@index([projectDeploymentId])
  // Fast case-insensitive substring search (ILIKE %term%) on document number/name
  // — powers the projects-search "documents.some.name" arm over ~4.2k docs.
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

// Junction table for document items - enables efficient queries for stock movements
model DocumentItem {
  id          String   @id @default(uuid()) @db.Uuid
  documentId  String   @db.Uuid
  itemId      String   @db.Uuid // Can be inventoryId or assetId
  itemType    ItemType // INVENTORY or ASSET
  sku         String? // SKU for reference
  description String? // Item description for reference
  quantity    Float    @default(0)
  unitPrice   Float?   @default(0)
  discount    Float?   @default(0)
  amount      Float?   @default(0)
  uom         String? // Unit of measure
  lineNumber  Int? // Position in document
  // True for service line items (labor, delivery fees, etc.).
  // Per Phase 5 Option 1, services from the import flow do NOT create DocumentItem
  // rows (they're skipped at the !inventoryItemId gate); this flag covers product
  // rows misclassified post-hoc as service, plus any future paths that DO create
  // service-row DocumentItems.
  isService   Boolean  @default(false)
  // True for fixed-asset purchases on a PO line. When PO is confirmed, the
  // journal-auto-post pipeline creates a FixedAsset record from this line so
  // it enters the depreciation schedule. User completes method + useful life
  // on the FA detail page after creation.
  isFixedAsset Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, itemId, lineNumber])
  @@index([itemId])
  @@index([documentId])
  @@index([itemId, itemType])
}

enum ItemType {
  INVENTORY
  ASSET
}

model Role {
  id             String       @id @default(uuid())
  name           String
  description    String?
  allowedModules String[]     @default([])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userRoles      UserRole[]
  permissions    Permission[] @relation("PermissionToRole")

  @@unique([name, organizationId])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")
}

model UserRole {
  id             String       @id @default(uuid())
  userId         String
  roleId         String
  createdAt      DateTime     @default(now())
  organizationId String
  assignedAt     DateTime     @default(now())
  assignedBy     String?
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId, organizationId])
}

model UserOrganization {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  salesmanCode   String? // Auto-generated code like S001, S002
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  joinedAt       DateTime     @default(now())
  lastActiveAt   DateTime?
  settings       Json?
  organization   Organization @relation(fields: [organizationId], references: [id])
  customers      Customer[] // Customers assigned to this salesman

  @@unique([userId, organizationId])
  @@unique([salesmanCode, organizationId])
}

model Project {
  id               String              @id @default(uuid()) @db.Uuid
  projectNumber    String? // e.g. PRJ-2026-001
  name             String
  description      String?
  organizationId   String?
  customerId       String?             @db.Uuid // direct FK; siteOffice still optional
  customerPoNumber String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  startDate        DateTime?
  endDate          DateTime?
  status           ProjectStatus       @default(pending)
  siteOfficeId     String?             @db.Uuid
  assignments      Assignment[]
  documents        Document[]
  deployments      ProjectDeployment[]
  organization     Organization?       @relation(fields: [organizationId], references: [id])
  siteOffice       SiteOffice?         @relation("SiteOfficeProjects", fields: [siteOfficeId], references: [id])
  customer         Customer?           @relation("CustomerProjects", fields: [customerId], references: [id])

  @@unique([projectNumber, organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  // Fast case-insensitive substring search (ILIKE %term%) on project name.
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

// A deployment groups one rental/sale event under a project.
// e.g. "DO202310-010 — 1× AF-90 monthly rental, deployed 2023-10-18"
// Recurring monthly invoices for that rental all link to the same deployment.
model ProjectDeployment {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String
  projectId      String @db.Uuid

  // Auto-assigned per project (1, 2, 3, ...). Displayed name is "Deployment N".
  // Nullable so existing rows aren't violated until the numbering pass runs.
  deploymentNumber Int?

  sourceDocumentId String?          @db.Uuid // The DO/invoice that started it (audit). Additional DOs attach via Document.projectDeploymentId.
  type             DeploymentType   @default(RENTAL)
  description      String? // Free-form user notes — no longer the displayed name.
  monthlyRate      Float? // for rentals; one-off price for sales
  currency         String?          @default("SGD")
  deployedDate     DateTime?
  offHiredDate     DateTime?
  status           DeploymentStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project        Project      @relation(fields: [projectId], references: [id])
  sourceDocument Document?    @relation("DeploymentSource", fields: [sourceDocumentId], references: [id])
  assignments    Assignment[]
  invoices       Document[]   @relation("DeploymentInvoices") // back-relation; now contains DOs AND invoices, partitioned by service-layer.

  @@unique([projectId, deploymentNumber])
  @@index([projectId, status])
  @@index([organizationId])
}

enum DeploymentType {
  RENTAL
  SALE
  SERVICE
}

enum DeploymentStatus {
  ACTIVE
  OFF_HIRED
  COMPLETED
  CANCELLED
}

model Assignment {
  id                  String  @id @default(uuid()) @db.Uuid
  projectId           String  @db.Uuid
  // Optional deployment grouping — assignments under a single rental/sale event
  projectDeploymentId String? @db.Uuid

  // Mode A: tracked inventory unit (existing)
  inventoryId String? @db.Uuid

  // Mode B: asset + quantity (new, for rentals without serials)
  assetId  String? @db.Uuid
  quantity Int?

  // Source invoice (idempotency on asset-mode + audit trail)
  documentId String? @db.Uuid

  startDate DateTime? @db.Timestamptz(6)
  endDate   DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now())

  inventory         Inventory?         @relation(fields: [inventoryId], references: [id])
  asset             Asset?             @relation(fields: [assetId], references: [id])
  document          Document?          @relation(fields: [documentId], references: [id])
  project           Project            @relation(fields: [projectId], references: [id])
  projectDeployment ProjectDeployment? @relation(fields: [projectDeploymentId], references: [id])

  @@unique([projectId, inventoryId])
  @@unique([projectId, assetId, documentId])
  @@index([assetId])
  @@index([documentId])
  @@index([projectDeploymentId])
}

model SiteOffice {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  address        String?
  customerId     String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  contactDetails ContactDetail[]
  projects       Project[]       @relation("SiteOfficeProjects")
  customer       Customer        @relation(fields: [customerId], references: [id])
}

model ContactDetail {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  email        String
  phone        String
  siteOfficeId String     @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  siteOffice   SiteOffice @relation(fields: [siteOfficeId], references: [id])
}

// Points of Contact (POC) for a customer. A customer can have many; the
// document editor exposes these in an "Attn To" dropdown so a user can
// address a document to a specific person (fills attention.name/phone/email).
model CustomerContact {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  email       String?
  designation String? // role / position, e.g. "Procurement Manager"
  isPrimary   Boolean  @default(false)
  customerId  String   @db.Uuid
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
}

model AuditLog {
  id             String      @id @default(uuid())
  userId         String
  userName       String?
  userEmail      String?
  action         String
  resource       String
  resourceId     String?
  resourceName   String?
  organizationId String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  status         AuditStatus @default(SUCCESS)
  errorMessage   String?
  createdAt      DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([organizationId])
  @@index([createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resource, createdAt])
  @@index([organizationId, action, createdAt])
  @@index([userId, action, createdAt])
}

enum ProjectStatus {
  pending
  ongoing
  completed
}

enum InventoryStatus {
  instock
  rental
  reserved
  maintenance
  sold
}

enum DocumentStatus {
  draft
  confirmed
  pending_delivery
  delivered_not_installed
  delivered_installed
  pending_payment
  paid
  pending_return
  returned
}

enum AuditStatus {
  SUCCESS
  FAILURE
  PENDING
}

model XeroConnection {
  id                    String       @id @default(uuid()) @db.Uuid
  organizationId        String       @unique
  tenantId              String       @unique
  accessToken           String
  refreshToken          String
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Module configuration per organization
// Orders — auto-created when a quotation is confirmed. Acts as the parent
// container from which POs / DOs / Invoices can be spun off for the items.
// Status is intentionally a free-form string for v1 (no auto-advance).
model Order {
  id                String   @id @default(uuid()) @db.Uuid
  orderNumber       String // e.g. ORD202605-001
  organizationId    String
  customerId        String?  @db.Uuid
  sourceQuotationId String?  @db.Uuid // Document.id of the originating quotation
  orderType         String? // Carried from the QF quotation's "Type" field: Project / Route Order
  status            String   @default("DRAFT") // DRAFT / IN_PROGRESS / COMPLETED / CANCELLED (free-form)
  items             Json // Snapshot at order-creation time: [{ itemCode, description, quantity, unitPrice, costPrice?, taggedAssetCode?, ... }]
  linkedDocuments   Json? // { po: [{id,name}], do: [{id,name}], invoice: [{id,name}] }
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id])
  customer        Customer?    @relation("CustomerOrders", fields: [customerId], references: [id])
  sourceQuotation Document?    @relation("OrderSourceQuotation", fields: [sourceQuotationId], references: [id])

  @@unique([orderNumber, organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([sourceQuotationId])
}

model OrganizationModule {
  id             String       @id @default(uuid())
  organizationId String
  moduleCode     String // 'ASSETS', 'INVENTORY', 'DOCUMENTS', 'PROJECTS', 'CUSTOMERS', 'INVOICES'
  enabled        Boolean      @default(true)
  displayName    String? // Custom label for this module
  icon           String? // Custom icon (Material UI icon name)
  sortOrder      Int? // Navigation order
  config         Json? // Module-specific configuration (routes, permissions, etc.)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, moduleCode])
  @@index([organizationId])
}

// Custom fields per organization per entity
model CustomField {
  id             String             @id @default(uuid())
  organizationId String
  entityType     String // 'Asset', 'Customer', 'Document', 'Inventory', 'Project'
  fieldName      String // Technical name (e.g., 'warranty_date')
  displayLabel   String // User-facing label (e.g., 'Warranty Expiry Date')
  fieldType      String // 'text', 'number', 'date', 'select', 'multiselect', 'boolean', 'file', 'richtext'
  required       Boolean            @default(false)
  options        Json? // For select/multiselect fields: [{value: 'val1', label: 'Label 1'}]
  defaultValue   String?
  validation     Json? // Validation rules: {min: 0, max: 100, pattern: '^[A-Z]'}
  sortOrder      Int?               @default(0)
  isActive       Boolean            @default(true)
  showInList     Boolean            @default(false) // Show in list/table views
  showInForm     Boolean            @default(true) // Show in forms
  groupName      String? // Group fields together in forms
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id])
  fieldValues    CustomFieldValue[]

  @@unique([organizationId, entityType, fieldName])
  @@index([organizationId, entityType])
}

// Store custom field values
model CustomFieldValue {
  id            String      @id @default(uuid())
  customFieldId String
  entityId      String // ID of the Asset/Customer/etc.
  entityType    String // 'Asset', 'Customer', etc.
  value         Json // Flexible storage for any type of value
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityId])
  @@index([entityId, entityType])
}

// UI Configuration per organization
model OrganizationUIConfig {
  id               String       @id @default(uuid())
  organizationId   String       @unique
  theme            Json? // Colors, fonts, spacing: {primaryColor: '#..', secondaryColor: '#..'}
  navigationConfig Json? // Custom navigation structure
  dashboardLayout  Json? // Dashboard widget configuration
  terminology      Json? // Custom labels: {asset: 'Equipment', customer: 'Client'}
  dateFormat       String?      @default("MM/dd/yyyy")
  timeFormat       String?      @default("12h")
  currency         String?      @default("USD")
  language         String?      @default("en")
  features         Json? // Feature flags: {enableProjects: true, enableDocumentAI: false}
  branding         Json? // Additional branding config
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id])
}

// Price History for tracking item prices from confirmed invoices
model PriceHistory {
  id             String   @id @default(uuid())
  assetId        String   @db.Uuid // Reference to the asset/item sold (REQUIRED)
  unitPrice      Float // Unit price at time of sale
  quantity       Float // Quantity sold
  uom            String? // Unit of measure
  totalAmount    Float // Total amount for this line item
  documentId     String   @db.Uuid // Reference to the document (invoice)
  documentNumber String // Invoice number for reference
  documentDate   DateTime // Date of the invoice
  customerId     String?  @db.Uuid // Customer who bought it
  customerName   String? // Customer name for reference
  organizationId String // Organization ID
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  document     Document     @relation(fields: [documentId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  asset        Asset        @relation(fields: [assetId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  // Indexes for fast queries
  @@index([assetId, organizationId])
  @@index([customerId, organizationId])
  @@index([documentDate])
  @@index([createdAt])
}

// Payment tracking for invoices
model Payment {
  id             String   @id @default(uuid())
  organizationId String
  customerId     String   @db.Uuid
  documentId     String   @db.Uuid
  amount         Float
  paymentDate    DateTime
  paymentMethod  String // cash, check, transfer, etc
  reference      String? // check number, transfer reference
  notes          String?
  // Same shape as Bill.attachments / BillPayment.attachments — the
  // customer payment proof (deposit slip, bank transfer screenshot).
  attachments    Json?
  createdBy      String // user ID who recorded payment
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  document     Document     @relation(fields: [documentId], references: [id])

  // Create related transaction when payment is recorded
  transactions Transaction[]

  @@index([customerId, organizationId])
  @@index([documentId])
  @@index([paymentDate])
  @@index([organizationId, paymentDate])
}

// Unified transaction ledger for all financial activities
model Transaction {
  id              String          @id @default(uuid())
  organizationId  String
  customerId      String          @db.Uuid
  transactionType TransactionType // invoice, payment, credit_note, debit_note, adjustment, opening_balance
  documentId      String?         @db.Uuid // nullable for adjustments/opening balance
  paymentId       String? // for payment transactions
  transactionDate DateTime
  reference       String? // document number or payment reference
  description     String
  debit           Float           @default(0)
  credit          Float           @default(0)
  balance         Float           @default(0) // running balance at time of transaction
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  document     Document?    @relation(fields: [documentId], references: [id])
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  // Indexes for fast SOA queries
  @@index([customerId, transactionDate])
  @@index([organizationId, transactionDate])
  @@index([documentId])
  @@index([paymentId])
}

// Customer balance tracking
model CustomerBalance {
  id                  String    @id @default(uuid())
  organizationId      String
  customerId          String    @db.Uuid
  openingBalance      Float     @default(0)
  currentBalance      Float     @default(0)
  lastTransactionDate DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation("CustomerToBalance", fields: [customerId, organizationId], references: [id, organizationId])

  @@unique([customerId, organizationId])
  @@index([organizationId])
}

enum TransactionType {
  INVOICE
  PAYMENT
  CREDIT_NOTE
  DEBIT_NOTE
  ADJUSTMENT
  OPENING_BALANCE
}

// Quantity adjustment history for untracked products
model QuantityAdjustment {
  id             String         @id @default(uuid()) @db.Uuid
  assetId        String         @db.Uuid
  previousQty    Int // Quantity before adjustment
  newQty         Int // Quantity after adjustment
  adjustmentType AdjustmentType // add, subtract, set
  amount         Int // Amount adjusted
  reason         String? // Optional reason for adjustment
  adjustedBy     String // User name/email who made the adjustment
  adjustedAt     DateTime       @default(now())
  organizationId String
  createdAt      DateTime       @default(now())

  // Relations
  asset        Asset        @relation(fields: [assetId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  // Indexes for fast queries
  @@index([assetId, adjustedAt])
  @@index([organizationId, adjustedAt])
}

enum AdjustmentType {
  ADD
  SUBTRACT
  SET
}

// Import staging table for Xero invoice backfill
model ImportInvoice {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String
  invoiceNumber     String
  date              String?
  customer          String?
  customerMatched   Boolean   @default(false)
  status            String? // Xero status: Paid, Approved, Draft
  source            String? // Receivable Invoice or Credit Note
  gross             Float?
  balance           Float?
  // AI-extracted metadata
  projectName       String?
  projectLocation   String?
  siteOfficeName    String?
  siteOfficeAddress String?
  doDate            String?
  doNumber          String?
  contactName       String?
  contactPhone      String?
  // Line items stored as JSON array
  lineItems         Json // Array of line item objects with asset_match, serial_numbers, etc.
  // Review status
  reviewStatus      String    @default("pending") // pending, confirmed, skipped
  skipReason        String?
  confirmedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([invoiceNumber, organizationId])
  @@index([organizationId, reviewStatus])
  @@index([organizationId])
}

// ============================================================
// ACCOUNTING
// ============================================================

// Chart of Accounts — one row per GL account per organization.
// Code prefixes follow the A's / Singapore SME convention:
//   Sxxxx = Sales, Cxxxx = Purchase / Cost of Sales, Ixxxx = Income,
//   Exxxx = Expenses, TXxxx = Tax, XIxxx = Extraordinary,
//   FAxxx = Fixed Assets, IAxxx = Intangible, CAxxx = Current Assets,
//   CLxxx = Current Liabilities, MTxxx/LTxxx = Medium/Long Term Liabilities,
//   DVxxx = Dividends, PCxxx = Share Capital, PDxxx = Depreciation Provision,
//   RPxxx = Retained Profit, CRxxx = Capital Reserve.
model ChartOfAccount {
  id               String   @id @default(uuid())
  organizationId   String
  code             String // e.g., "S0001", "CA001", "CL300"
  name             String // e.g., "Credit Sales", "Trade Receivables"
  description      String?
  accountType      String // High-level type — see AccountType enum-ish values in service
  category         String // 'PNL' | 'BALANCE_SHEET'
  normalBalance    String // 'DEBIT' | 'CREDIT'
  isControlAccount Boolean  @default(false) // Debtor / Creditor / GST control accounts
  isSystem         Boolean  @default(false) // Seeded by default; cannot be deleted
  isActive         Boolean  @default(true)
  parentAccountId  String? // Optional sub-account hierarchy
  // Xero pull-sync: AccountID from Xero.
  xeroId           String?  @unique
  xeroLastSyncAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ChartOfAccount?    @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  children     ChartOfAccount[]   @relation("AccountHierarchy")
  journalLines JournalEntryLine[]
  budgets      Budget[]

  @@unique([organizationId, code])
  @@index([organizationId, accountType])
  @@index([organizationId, category])
}

// One-per-organization accounting configuration (A's "Installation" screen).
model AccountingSetting {
  id             String @id @default(uuid())
  organizationId String @unique

  // ---------- Operation Settings ----------
  baseCurrency          String  @default("SGD")
  // Next-number counters per document type (e.g. { "invoice": 119, "quotation": 22, ... })
  nextNumbers           Json?
  // Per-doc-type prefix overrides (e.g. { "invoice": "INV", "quotation": "QO" })
  numberPrefixes        Json?
  activateLastSoldPrice Boolean @default(true)
  activateLastBuyPrice  Boolean @default(true)

  // ---------- Accounts Settings ----------
  yearOpeningDate   DateTime?
  yearOpeningStock  Float?    @default(0)
  monthOpeningDate  DateTime?
  monthOpeningStock Float?    @default(0)
  monthClosingStock Float?    @default(0)

  // ---------- Tax Settings ----------
  taxRegistrationNumber String?
  taxDefaultPercentage  Float?  @default(9)
  taxReference          String? @default("GST") // GST / VAT / etc.

  // ---------- Accounts Definition ----------
  // Code-range windows (e.g. { sales: { from: "S0001", to: "S9999" }, ... })
  accountCodeRanges Json?
  // Control-account code references (e.g. { debtorControl: "CA001", creditorControl: "CL001", taxLiabilities: "CL300", ... })
  controlAccounts   Json?

  // ---------- AP / Bills ----------
  // Bills over this amount require Admin approval before posting. 0 = no
  // threshold (every bill auto-eligible). Configurable per org.
  billApprovalThreshold Float? @default(5000)

  // ---------- Perpetual Inventory ----------
  // When ON, journal auto-post writes Dr Inventory / Cr Cash on PO confirm and
  // Dr COGS / Cr Inventory on invoice post (instead of expensing purchases
  // directly to COGS). Closing Stock then comes from the Inventory GL account
  // balance and the P&L Closing Stock filter input becomes redundant. OFF by
  // default — preserves existing periodic-inventory behavior for legacy orgs.
  enablePerpetualInventory Boolean @default(false)

  // ---------- Period Locking ----------
  // Inclusive cut-off date for the last closed period. Posting / editing
  // journal entries with entryDate <= this date is rejected. Updated by the
  // Smart Close Wizard on Month-End / Year-End run.
  lockedThroughDate DateTime?
  // Log of past close runs — array of { type, lockedThrough, runAt, runBy,
  // yearEndJournalEntryId? } so users can audit / unwind if needed.
  closeHistory      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================================
// JOURNAL ENTRIES — General Ledger
// ============================================================
//
// JournalEntry is the GL header (one transaction = many balanced lines).
// Auto-created on invoice confirm + payment record, plus manual entries
// (Journal Voucher). Posting locks the entry; voiding creates a reversing entry.

model JournalEntry {
  id             String   @id @default(uuid())
  organizationId String
  journalNumber  String // e.g., "JV-000001"
  entryDate      DateTime
  type           String // MANUAL | INVOICE | PAYMENT | CREDIT_NOTE | DEBIT_NOTE | OPENING_BALANCE | ADJUSTMENT
  status         String   @default("DRAFT") // DRAFT | POSTED | VOID
  reference      String? // Source document number, payment reference, etc.
  description    String?
  totalDebit     Float    @default(0)
  totalCredit    Float    @default(0)
  currency       String   @default("SGD")

  // Source linkage (only one is set depending on type)
  sourceDocumentId String?
  sourcePaymentId  String?

  postedAt        DateTime?
  postedBy        String?
  voidedAt        DateTime?
  voidedBy        String?
  reversesEntryId String? // If this is a reversing entry, points to original

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines        JournalEntryLine[]

  @@unique([organizationId, journalNumber])
  @@index([organizationId, entryDate])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([sourceDocumentId])
  @@index([sourcePaymentId])
}

model JournalEntryLine {
  id             String  @id @default(uuid())
  journalEntryId String
  accountId      String // FK to ChartOfAccount.id
  lineNumber     Int
  description    String?
  debit          Float   @default(0)
  credit         Float   @default(0)

  // Multi-currency support — set when the org operates in multiple currencies
  foreignAmount Float?
  exchangeRate  Float?

  // Cost-center tag for dimensional reporting. Optional — null = unallocated /
  // "general overhead". Set by the user on manual JE entry or auto-suggested
  // by the journal-auto-post pipeline based on document context + LLM hint.
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@index([costCenterId])
}

// ============================================================
// COST CENTERS / DEPARTMENTS
// ============================================================
// Dimensional tag attached to JournalEntryLine for "P&L by department" style
// reporting. Hierarchical via parentId — e.g. "Operations" → "Field Services".
model CostCenter {
  id             String   @id @default(uuid())
  organizationId String
  code           String   // short code, e.g. OPS, SALES, R&D
  name           String   // human label, e.g. "Operations — Field"
  description    String?
  parentId       String?
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       CostCenter?        @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children     CostCenter[]       @relation("CostCenterHierarchy")
  journalLines JournalEntryLine[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

// ============================================================
// FIXED ASSETS REGISTER + DEPRECIATION
// ============================================================
// One row per depreciable asset (vehicles, machinery, office equipment, etc.).
// Created either manually or auto-from-PO when a DocumentItem has
// isFixedAsset=true. Monthly depreciation is posted by the Smart Close Wizard
// during Month-End Close and logged as DepreciationEntry rows.
model FixedAsset {
  id                String   @id @default(uuid())
  organizationId    String
  code              String   // org-unique tag, e.g. FA-001
  name              String   // e.g. "Delivery van #1"
  description       String?
  category          String?  // free-form bucket (Vehicle / Office Equipment / Machinery)
  // Acquisition
  cost              Float    // purchase cost (excl tax) — depreciation basis
  salvageValue      Float    @default(0)
  inServiceDate     DateTime // date depreciation begins
  // Depreciation method
  // STRAIGHT_LINE | DECLINING_BALANCE | UNITS_OF_PRODUCTION
  method            String   @default("STRAIGHT_LINE")
  usefulLifeMonths  Int?     // required for STRAIGHT_LINE
  decliningRate     Float?   // percent per period, e.g. 20 → 20% reducing-balance
  totalUnits        Float?   // required for UNITS_OF_PRODUCTION (total life-units)
  unitsPerPeriod    Float?   // user-entered units consumed each period for U-O-P
  // Linkage
  sourcePoId        String?  // PO document this FA was created from (optional)
  // Lifecycle
  disposedAt        DateTime?
  disposalProceeds  Float?
  isActive          Boolean  @default(true)

  // GL accounts used when posting depreciation. Optional — falls back to
  // controlAccounts.{depreciationProvision, depreciationExpense} on settings,
  // or PD001 / EX410 by default.
  depreciationProvisionAccountId String?
  depreciationExpenseAccountId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries      DepreciationEntry[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
}

// Log of posted depreciation entries — one per asset per period. Useful for
// audit (proves the FA register reconciles with GL) and for not double-posting.
model DepreciationEntry {
  id              String   @id @default(uuid())
  fixedAssetId    String
  organizationId  String
  periodYear      Int
  periodMonth     Int      // 1-12
  amount          Float
  journalEntryId  String?  // back-link to the JE that posted this depreciation
  postedAt        DateTime @default(now())

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@unique([fixedAssetId, periodYear, periodMonth])
  @@index([organizationId, periodYear, periodMonth])
}

// ============================================================
// BUDGETS
// ============================================================
// One budget figure per GL account per calendar month. Compared to actual P&L
// activity in the "Budget vs Actual" Reports tab.
model Budget {
  id             String  @id @default(uuid())
  organizationId String
  accountId      String  // FK to ChartOfAccount.id
  year           Int
  month          Int     // 1-12
  amount         Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, year, month])
  @@index([organizationId, year])
}

// ============================================================
// BILLS (Accounts Payable)
// ============================================================
// Supplier bills. Separate doctype from Document/Invoice — invoices are
// sales-side, bills are purchase-side. Lifecycle:
//   DRAFT → PENDING_APPROVAL (if amount > threshold) → POSTED → PAID → VOID
// "PENDING_APPROVAL" is skipped when bill amount is at/below the org's
// billApprovalThreshold (configurable in AccountingSetting).
//
// Lines are JSON-stored (same shape as recurring journals' lines), each row:
//   { description, quantity, unitPrice, amount, accountId?, taxAmount? }
//
// `sourcePoId` links a bill back to a Purchase Order document for 3-way
// matching (PO → receipt → bill). Discrepancy detection done in the service.
//
// `inboundMeta` captures provenance for bills created via PDF/LLM extract or
// email forward — useful for audit + debugging extraction accuracy.
model Bill {
  id             String   @id @default(uuid())
  organizationId String
  supplierId     String   @db.Uuid
  billNumber     String   // supplier's invoice number / our internal ref
  billDate       DateTime
  dueDate        DateTime?
  status         String   @default("DRAFT")
    // DRAFT | PENDING_APPROVAL | POSTED | PAID | VOID
  reference      String?
  description    String?
  // Totals
  subtotal       Float    @default(0)
  taxAmount      Float    @default(0)
  totalAmount    Float    @default(0)
  amountPaid     Float    @default(0)
  currency       String   @default("SGD")
  // Lines: [{ description, quantity, unitPrice, amount, accountId?, taxRate?, taxAmount? }]
  lines          Json
  // PO linkage (3-way match)
  sourcePoId     String?
  // Match flags surfaced to the UI when bill is from a PO
  matchStatus    String?  // MATCHED | QTY_DIFF | AMOUNT_DIFF | LINE_DIFF
  matchDetails   Json?
  // Provenance for non-manual entries
  inboundChannel String?  // MANUAL | UPLOAD | EMAIL | FROM_PO
  inboundMeta    Json?    // { extractedBy: 'claude-sonnet-4-6', originalFileKey, emailFromAddress, ... }
  // GL linkage — set when POSTED
  journalEntryId String?
  // Approval audit
  approvedBy     String?
  approvedAt     DateTime?
  postedAt       DateTime?
  postedBy       String?
  voidedAt       DateTime?
  voidedBy       String?

  // Files attached at any point in the bill lifecycle — the supplier's
  // original invoice PDF, supporting docs, receipts. Shape:
  //   [{ fileKey, fileName, mimeType, label?, uploadedAt, uploadedBy }]
  attachments    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier     @relation(fields: [supplierId], references: [id])

  @@unique([organizationId, billNumber, supplierId])
  @@index([organizationId, status])
  @@index([organizationId, billDate])
  @@index([supplierId])
  @@index([sourcePoId])
}

// AP-side payment voucher — one row per payment made against a supplier bill.
// Mirrors the AR `Payment` table but on the bill/supplier side. A single bill
// may have many BillPayment rows (partial payments); the bill is PAID when
// sum(amount) reaches the bill total.
//
// `billId` references a Document row with type='BILL' (no FK constraint —
// bills now live in the unified Document table, and we use the same id space).
// On create the service auto-posts a JournalEntry (Dr AP control / Cr bank
// account) and stamps `journalEntryId` here for traceability.
model BillPayment {
  id              String   @id @default(uuid())
  organizationId  String
  billId          String   // → Document.id where type='BILL'
  supplierId      String   @db.Uuid
  amount          Float
  paymentDate     DateTime
  paymentMethod   String   // cash | cheque | transfer | giro | other
  reference       String?  // cheque number / TT reference / paynow ref
  notes           String?
  // ChartOfAccount.id of the cash/bank account credited. Picker should
  // filter via JournalService.isCashOrBankAccount.
  bankAccountId   String
  // JE auto-posted on create — null only briefly between insert and post.
  journalEntryId  String?
  // Payment proof — cheque scan, bank TT advice, paynow screenshot.
  attachments     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier     @relation(fields: [supplierId], references: [id])

  @@index([organizationId, paymentDate])
  @@index([billId])
  @@index([supplierId])
}

// ============================================================
// BANK RECONCILIATION
// ============================================================
// One BankStatementImport per uploaded statement. Each row of the statement
// becomes a BankStatementLine that the user matches to a JournalEntryLine on
// the bank account, or posts as a new JE (for charges/interest/transfers).
model BankStatementImport {
  id              String   @id @default(uuid())
  organizationId  String
  bankAccountId   String   // FK to ChartOfAccount.id of the bank account
  source          String   // CSV | PDF | MANUAL
  filename        String?
  // Date window the statement covers (best-guess from first/last line dates).
  periodStart     DateTime?
  periodEnd       DateTime?
  // Statement's ending balance (read from CSV last row / PDF total). Used to
  // verify reconciliation: book balance + outstanding ?= bank ending balance.
  endingBalance   Float?
  // CSV column-mapping the user saved on first import for this bank account.
  // Stored on the import too so we know what we used.
  columnMapping   Json?
  notes           String?

  createdAt DateTime @default(now())
  createdBy String?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines        BankStatementLine[]

  @@index([organizationId, bankAccountId])
}

model BankStatementLine {
  id             String   @id @default(uuid())
  importId       String
  organizationId String
  bankAccountId  String   // duplicated from import for query convenience
  // Parsed fields
  date           DateTime
  description    String
  reference      String?
  // Signed: positive = credit (money in), negative = debit (money out). UI
  // can split into debit/credit columns from this.
  amount         Float
  runningBalance Float?
  // Matching
  // PENDING | MATCHED | POSTED_NEW | IGNORED
  status         String   @default("PENDING")
  matchedJournalLineId String?  // the JournalEntryLine this row matched
  matchedAt      DateTime?
  matchedBy      String?
  // For POSTED_NEW: the JE we created from this unmatched line.
  postedJournalEntryId String?
  // LLM-suggested GL account when unmatched (for the "post as new" flow).
  suggestedAccountId   String?
  suggestionConfidence Float?
  suggestionReason     String?

  createdAt DateTime @default(now())

  import BankStatementImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([organizationId, bankAccountId, status])
  @@index([organizationId, date])
}

// ============================================================
// XERO SYNC (PULL-only)
// ============================================================
// Per-org mapping between an AIMS ChartOfAccount and a Xero account. Source
// of the mapping is tracked so the UI can show "auto-suggested by AI" vs
// "manually confirmed" — important because we never want to overwrite a
// manual mapping on a subsequent auto-map run.
model XeroAccountMapping {
  id              String   @id @default(uuid())
  organizationId  String
  // AIMS side
  aimsAccountId   String?  // null = unmatched ("Xero account not yet mapped")
  aimsAccountCode String   // duplicated for diff/audit even if aims account is later deleted
  // Xero side
  xeroAccountId   String   // Xero's AccountID GUID
  xeroAccountCode String?  // Xero's account code (some Xero accts have no code)
  xeroAccountName String
  xeroAccountType String?  // REVENUE | EXPENSE | ASSET | LIABILITY | EQUITY...
  // Confidence + source
  source          String   @default("AUTO") // AUTO | MANUAL | CREATED
  confidence      Float?   // 0-1, set when source=AUTO
  reason          String?
  confirmedAt     DateTime? // set when user clicks "approve"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, xeroAccountId])
  @@index([organizationId, aimsAccountId])
}

// Audit log: one row per "Sync Now" click. Tracks what was pulled + counts.
model XeroSyncRun {
  id              String   @id @default(uuid())
  organizationId  String
  // PULL scope flags — JSON for forward-compat as we add bills/invoices.
  // e.g. { accounts: true, contacts: true, invoices: false, ... }
  scope           Json
  status          String   @default("RUNNING") // RUNNING | SUCCESS | PARTIAL | FAILED
  // Per-resource counts: { accountsCreated, accountsUpdated, contactsCreated, ... }
  counts          Json?
  // Per-resource errors so a single bad record doesn't blow the whole run.
  errors          Json?

  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  startedBy   String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, startedAt(sort: Desc)])
}

// ============================================================
// RECURRING JOURNAL TEMPLATES
// ============================================================
// User-defined templates that auto-create DRAFT journal entries on a schedule.
// Used for rent, accruals, depreciation, prepayments. Lazy trigger: the
// Finance Hub checks for due-and-active templates on load and creates drafts.
model RecurringJournalTemplate {
  id             String   @id @default(uuid())
  organizationId String
  name           String   // e.g. "Office rent — May 2026"
  description    String?
  reference      String?  // optional reference applied to the created JE
  // DAILY | WEEKLY | MONTHLY | QUARTERLY | YEARLY
  frequency      String
  // Next date this template is due to run. Cron / hub-load compares to today.
  nextRunDate    DateTime
  // Last time this template successfully created an entry. Helps users sanity-
  // check that automation is working.
  lastRunAt      DateTime?
  lastRunEntryId String?
  // Active flag — paused templates skip without erroring.
  isActive       Boolean  @default(true)
  // Line clones, stored as JSON: [{ accountId, description, debit, credit }]
  lines          Json
  // Optional end date — template stops creating entries after this.
  endDate        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@index([organizationId, nextRunDate])
}

// Field-service maintenance report captured via the NFC scan PWA.
// One per service visit; tied to an asset, signed by the customer/recipient on-site.
model MaintenanceServiceReport {
  id                String                         @id @default(uuid()) @db.Uuid
  organizationId    String
  assetId           String                         @db.Uuid
  // Optional link to a specific inventory unit (when isTracked assets have serials)
  inventoryId       String?                        @db.Uuid
  // Clerk user id of the technician who performed the work
  technicianUserId  String
  technicianName    String?
  description       String // What was serviced / issue / resolution
  // S3 keys for proof-of-service photos
  photos            String[]                       @default([])
  // S3 key OR base64 PNG (matches Document signature handling)
  signature         String?
  signedByName      String? // Customer / recipient name
  signedAt          DateTime?
  status            MaintenanceServiceReportStatus @default(draft)
  // Discriminator for what kind of field activity this row represents.
  // SERVICE   — traditional maintenance/repair visit (default).
  // DO_START  — technician started delivery of an existing DO (label: "Delivery Started").
  // DO_ACK    — technician confirmed final handover/installation of a DO (label: "Delivery Acknowledged").
  kind              MaintenanceReportKind          @default(SERVICE)
  // FK to the Document this report relates to.
  //   DO_START / DO_ACK → the DO being delivered.
  //   SERVICE           → null.
  // Historic DO_ACK rows backfilled from the description-prefix scheme may
  // have null documentId; gating logic only considers MSRs with non-null FK.
  documentId        String?                        @db.Uuid
  document          Document?                      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  // GPS captured at submission time. Optional — submission proceeds without
  // GPS if browser geolocation is denied or unavailable.
  latitude          Float?
  longitude         Float?
  // Reverse-geocoded human-readable label (e.g. "12 Tuas South Ave 3").
  // Schema-ready for future enablement; v1 of the field flow leaves it null.
  locationLabel     String?
  // Site ID returned by water-sg when a site is created from this
  // acknowledgment. Null = no site created (gate off, not SIDS, or the
  // best-effort POST failed). Additive audit footprint, never read by gating.
  waterSgSiteId     String?
  // Sequential per-org SERVICE report number (paper-form analogue). Null for
  // DO_START / DO_ACK rows and for SERVICE rows created by the legacy flow.
  reportNumber      Int?
  // Structured payload for the 5-page MSR form (customer link, checklist,
  // times, tech signature key, etc.). Schemaless on purpose — see the field
  // PWA's submit handler for the canonical shape.
  serviceData       Json?
  // Set by the field tech at submit time. When false, the report is auto-
  // emailed to the customer (PDF attached) and the loop closes. When true,
  // an Invoice document must be created from the office before customer
  // contact — surfaced on the dashboard as "Pending Invoice".
  paymentRequired   Boolean                        @default(false)
  // FK to the Invoice Document created off this report (set when an office
  // user clicks Create Invoice on the detail page). Distinct from the
  // DO-flow `documentId` above so the two linkages don't fight.
  invoiceDocumentId String?                        @db.Uuid
  invoiceDocument   Document?                      @relation("MsrInvoice", fields: [invoiceDocumentId], references: [id], onDelete: SetNull)
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  organization  Organization           @relation(fields: [organizationId], references: [id])
  asset         Asset                  @relation(fields: [assetId], references: [id])
  inventory     Inventory?             @relation(fields: [inventoryId], references: [id])
  // Background-tracked GPS pings collected during this delivery. Populated
  // only for kind=DO_START rows — DO_ACK and SERVICE rows have none.
  locationPings DeliveryLocationPing[]

  @@unique([organizationId, reportNumber])
  @@index([organizationId, assetId, createdAt])
  @@index([assetId, status])
  @@index([organizationId, kind, createdAt])
  @@index([documentId, kind])
  @@index([organizationId, reportNumber(sort: Desc)])
}

// Live-tracked GPS pings emitted by the field-tech app between Start Delivery
// and Acknowledge Delivery. Linked to the DO_START MaintenanceServiceReport;
// the office portal renders these as a polyline on a Leaflet map.
//
// Cardinality: 1 DO_START → N pings (typically 1 every 10s while delivery
// active). Cascade-deleted with the parent report.
model DeliveryLocationPing {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @db.Uuid
  latitude  Float
  longitude Float
  accuracy  Float? // metres of horizontal uncertainty (68% confidence)
  speed     Float? // metres per second
  heading   Float? // degrees from true north (0..360)
  timestamp DateTime // capture time from the phone
  createdAt DateTime @default(now()) // server-side receive time

  report MaintenanceServiceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Idempotency anchor — duplicate batch retries don't double-insert.
  @@unique([reportId, timestamp])
  // Lookups are always "all pings for report X, ordered by time" → composite
  // index covers both filter and order.
  @@index([reportId, timestamp])
}

enum MaintenanceServiceReportStatus {
  draft
  completed
}

enum MaintenanceReportKind {
  SERVICE
  DO_START
  DO_ACK
  DO_INSTALL
}
