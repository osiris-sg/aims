# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aims"

# Clerk Authentication
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_WEBHOOK_SECRET=your_webhook_secret

# AWS S3 Configuration for PDF Storage
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=aims-documents

# Xero Integration (Optional)
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=http://localhost:3001/api/xero/callback

# OpenAI (Optional)
OPENAI_API_KEY=your_openai_api_key

# Resend Email Service
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=invoices@aspireapp.com

# Application
PORT=3001
NODE_ENV=development