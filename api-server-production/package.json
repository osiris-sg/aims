{
  "name": "api-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:sync": "npx prisma db push",
    "seed": "ts-node prisma/seed.ts",
    "assign-superadmin": "ts-node scripts/assign-superadmin.ts",
    "assign-osirisadmin": "ts-node scripts/assign-osirisadmin.ts",
    "debug-user-roles": "ts-node scripts/debug-user-roles.ts",
    "setup-database": "ts-node scripts/setup-database.ts",
    "setup-user": "ts-node scripts/setup-user.ts",
    "migrate-sales-nav": "ts-node scripts/migrate-to-sales-navigation.ts",
    "migrate-sales-nav:dry": "ts-node scripts/migrate-to-sales-navigation.ts --dry-run",
    "migrate-inventory-nav": "ts-node scripts/migrate-to-inventory-navigation.ts",
    "migrate-inventory-nav:dry": "ts-node scripts/migrate-to-inventory-navigation.ts --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.779.0",
    "@aws-sdk/s3-request-presigner": "^3.908.0",
    "@clerk/backend": "^1.24.0",
    "@clerk/clerk-sdk-node": "^4.13.23",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.4.1",
    "@types/moment": "^2.11.29",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "lucide-react": "^0.510.0",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.2.0",
    "passport-custom": "^1.1.1",
    "pdf-parse": "^2.2.2",
    "pdf-to-png-converter": "^3.10.0",
    "pg": "^8.13.3",
    "puppeteer": "^24.24.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.4.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "xero-node": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.3.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "^6.4.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
