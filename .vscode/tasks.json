{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Development Environment",
      "type": "shell",
      "command": "node",
      "args": ["scripts/open-terminals.js"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Start Portal Development",
      "type": "shell",
      "command": "cd portal-production && echo '=== Starting Portal Development Server ===' && npm run dev",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Start API Development",
      "type": "shell",
      "command": "cd api-server-production && echo '=== Starting API Development Server ===' && npm run start:dev",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Open Prisma Studio",
      "type": "shell",
      "command": "cd api-server-production && echo '=== Opening Prisma Studio ===' && npm run db:studio",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Open Portal Terminal",
      "type": "shell",
      "command": "cd portal-production && echo '=== Portal Production Terminal ===' && pwd && exec $SHELL",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
