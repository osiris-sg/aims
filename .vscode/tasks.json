        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Open API Terminal",
      "type": "shell",
      "command": "cd api-server-production && echo '=== API Server Terminal ===' && pwd && exec $SHELL",
      "group": "build",
